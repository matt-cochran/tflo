---
import { codeToHtml } from 'shiki';

export interface Props {
  code: string;
  lang?: string;
  class?: string;
  /** GitHub URL to the source file this code comes from.
   * Base URL: https://github.com/matt-cochran/tflo/
   * Example: tflo-examples/examples/sma-from-scratch/main.rs */
  src?: string;
}

const { code, lang = 'rust', class: cls, src } = Astro.props;

const html = await codeToHtml(code, {
  lang,
  theme: 'github-dark',
});
---

<div class={`overflow-x-auto mb-1 rounded-xl ${cls ?? ''}`}>
  <Fragment set:html={html} />
</div>
{
  src && (
    <div class="mb-6 text-right">
      <a
        href={`https://github.com/matt-cochran/tflo/blob/main/${src}`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs text-text-muted hover:text-primary transition-colors no-underline"
      >
        View source
      </a>
    </div>
  )
}
