<!--
Search command palette — Ctrl+K / Cmd+K to open.
Searches blog posts and docs from the static search-index.json.
-->

<div id="search-palette-container"></div>

<script>
  // Declare globals for the header button
  declare global {
    interface Window {
      __openSearch: () => void;
      __closeSearch: () => void;
    }
  }

  (function() {
    const STORAGE_KEY = 'tflo-search-index';

    interface SearchEntry {
      title: string;
      description: string;
      tags: string[];
      slug: string;
      pubDate: string;
    }

    async function getIndex(): Promise<SearchEntry[]> {
      const cached = sessionStorage.getItem(STORAGE_KEY);
      if (cached) {
        try { return JSON.parse(cached) as SearchEntry[]; } catch { /* ignore */ }
      }
      try {
        const res = await fetch('/search-index.json');
        const data: SearchEntry[] = await res.json();
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify(data));
        return data;
      } catch {
        return [];
      }
    }

    function matches(entry: SearchEntry, query: string): boolean {
      const q = query.toLowerCase();
      return (
        entry.title.toLowerCase().includes(q) ||
        entry.description.toLowerCase().includes(q) ||
        (entry.tags || []).some((t: string) => t.toLowerCase().includes(q))
      );
    }

    function highlight(text: string, query: string): string {
      if (!query.trim()) return text;
      const q = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      const re = new RegExp(`(${q})`, 'gi');
      return text.replace(re, '<mark class="bg-accent/30 text-white rounded-sm">$1</mark>');
    }

    async function init(): Promise<void> {
      const container = document.getElementById('search-palette-container');
      if (!container) return;

      const index: SearchEntry[] = await getIndex();

      const overlay = document.createElement('div');
      overlay.id = 'search-palette';
      overlay.className = 'fixed inset-0 z-[100] hidden';
      overlay.innerHTML = `
        <div class="fixed inset-0 bg-black/60 backdrop-blur-sm" data-search-close></div>
        <div class="fixed inset-0 flex items-start justify-center pt-[15vh] px-4">
          <div class="w-full max-w-lg bg-bg-card border border-border rounded-xl shadow-2xl overflow-hidden">
            <div class="relative">
              <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/>
              </svg>
              <input
                type="text"
                id="search-input"
                class="w-full bg-transparent text-white text-lg pl-12 pr-4 py-4 outline-none placeholder:text-text-muted"
                placeholder="Search docs and blog posts..."
                autofocus
              />
            </div>
            <div id="search-results" class="max-h-80 overflow-y-auto border-t border-border">
              <div class="px-4 py-6 text-center text-text-muted text-sm">Type to search...</div>
            </div>
            <div class="flex items-center gap-3 px-4 py-2 border-t border-border text-xs text-text-muted">
              <span><kbd class="px-1.5 py-0.5 rounded bg-bg text-text-muted font-mono text-xs">↑↓</kbd> navigate</span>
              <span><kbd class="px-1.5 py-0.5 rounded bg-bg text-text-muted font-mono text-xs">↵</kbd> open</span>
              <span><kbd class="px-1.5 py-0.5 rounded bg-bg text-text-muted font-mono text-xs">Esc</kbd> close</span>
            </div>
          </div>
        </div>
      `;
      container.appendChild(overlay);

      const input = document.getElementById('search-input') as HTMLInputElement | null;
      const resultsContainer = document.getElementById('search-results') as HTMLElement | null;
      let selectedIndex = -1;
      let currentResults: SearchEntry[] = [];

      function renderResults(query: string): void {
        if (!query.trim()) {
          if (resultsContainer) {
            resultsContainer.innerHTML = '<div class="px-4 py-6 text-center text-text-muted text-sm">Type to search...</div>';
          }
          currentResults = [];
          selectedIndex = -1;
          return;
        }

        currentResults = index.filter((entry: SearchEntry) => matches(entry, query));
        selectedIndex = -1;

        if (!resultsContainer) return;

        if (currentResults.length === 0) {
          resultsContainer.innerHTML = '<div class="px-4 py-6 text-center text-text-muted text-sm">No results found.</div>';
          return;
        }

        resultsContainer.innerHTML = currentResults.map((entry: SearchEntry, i: number) => `
          <a
            href="${entry.slug}"
            class="block px-4 py-3 hover:bg-bg-card-hover transition-colors border-b border-border last:border-b-0${i === selectedIndex ? ' bg-bg-card-hover' : ''}"
            data-index="${i}"
          >
            <div class="flex items-start justify-between gap-2">
              <div>
                <div class="text-sm font-medium text-white">${highlight(entry.title, query)}</div>
                <div class="text-xs text-text-muted mt-0.5 line-clamp-1">${highlight(entry.description, query)}</div>
              </div>
              <div class="flex flex-col items-end gap-1 shrink-0">
                ${entry.pubDate ? `<span class="text-[10px] text-text-muted whitespace-nowrap">${entry.pubDate}</span>` : ''}
                <span class="text-[10px] uppercase tracking-wider text-primary/70">${entry.tags?.[0] || ''}</span>
              </div>
            </div>
          </a>
        `).join('');
      }

      function openPalette(): void {
        overlay.classList.remove('hidden');
        setTimeout(() => input?.focus(), 50);
        document.body.style.overflow = 'hidden';
      }

      function closePalette(): void {
        overlay.classList.add('hidden');
        document.body.style.overflow = '';
      }

      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          if (overlay.classList.contains('hidden')) openPalette();
          else closePalette();
        }
        if (e.key === 'Escape') closePalette();
      });

      if (input) {
        input.addEventListener('input', (e: Event) => {
          const target = e.target as HTMLInputElement;
          renderResults(target.value);
        });

        input.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (selectedIndex < currentResults.length - 1) {
              selectedIndex++;
              highlightSelected();
            }
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (selectedIndex > 0) {
              selectedIndex--;
              highlightSelected();
            }
          } else if (e.key === 'Enter') {
            e.preventDefault();
            if (selectedIndex >= 0 && selectedIndex < currentResults.length) {
              window.location.href = currentResults[selectedIndex].slug;
            } else if (currentResults.length > 0) {
              window.location.href = currentResults[0].slug;
            }
          }
        });
      }

      function highlightSelected(): void {
        if (!resultsContainer) return;
        const items = resultsContainer.querySelectorAll('a');
        items.forEach((item: Element, i: number) => {
          item.classList.toggle('bg-bg-card-hover', i === selectedIndex);
        });
        if (selectedIndex >= 0 && items[selectedIndex]) {
          items[selectedIndex].scrollIntoView({ block: 'nearest' });
        }
      }

      overlay.querySelectorAll('[data-search-close]').forEach((el: Element) => {
        el.addEventListener('click', closePalette);
      });

      window.__openSearch = openPalette;
      window.__closeSearch = closePalette;
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => { init(); });
    } else {
      init();
    }
  })();
</script>
