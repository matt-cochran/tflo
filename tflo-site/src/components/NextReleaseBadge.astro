---
export interface Props {
  /** Visual variant. `inline` renders a compact pill suitable for use next
   * to a heading or table cell; `block` adds a hairline of margin so it
   * stands alone above a section. Defaults to `inline`. */
  variant?: 'inline' | 'block';
  /** Override the label. Defaults to "Next release". */
  label?: string;
  /** Visual style. `next` is the default amber pill matching the pre-1.0
   * badge. `backlog` is a grey pill used for items in the interop backlog. */
  tone?: 'next' | 'backlog';
}

const { variant = 'inline', label, tone = 'next' } = Astro.props;

const toneClasses = tone === 'backlog'
  ? 'border-border bg-bg-card text-text-muted'
  : 'border-amber-500/40 bg-amber-500/10 text-amber-300';

const dotClasses = tone === 'backlog' ? 'bg-text-muted' : 'bg-amber-400';

const displayLabel = label ?? (tone === 'backlog' ? 'Interop backlog' : 'Next release');

const wrapperClass = variant === 'block' ? 'inline-block mb-3' : 'inline-block align-middle ml-2';
---

<span class={wrapperClass}>
  <span class={`inline-flex items-center gap-1.5 rounded-full border px-2.5 py-0.5 text-[11px] font-medium uppercase tracking-wide ${toneClasses}`}>
    <span class={`w-1.5 h-1.5 rounded-full ${dotClasses}`}></span>
    {displayLabel}
  </span>
</span>
