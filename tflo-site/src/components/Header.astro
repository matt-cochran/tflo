---
// Header component used in BaseLayout
---

<header class="sticky top-0 z-50 border-b border-border bg-bg/80 backdrop-blur-sm">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-bold text-xl text-white">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none" class="text-primary">
          <rect width="32" height="32" rx="6" fill="currentColor" />
          <path d="M9 16L14 21L23 12" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        tflo
      </a>

      <div class="hidden sm:flex items-center gap-6">
        <a href="/docs" class="text-sm font-medium text-text-muted hover:text-white transition-colors">
          Docs
        </a>
        <a href="/positioning" class="text-sm font-medium text-text-muted hover:text-white transition-colors">
          Positioning
        </a>
        <a href="/use-cases" class="text-sm font-medium text-text-muted hover:text-white transition-colors">
          Use Cases
        </a>
        <a href="/blog" class="text-sm font-medium text-text-muted hover:text-white transition-colors">
          Blog
        </a>
        <a href="/docs/quick-start" class="text-sm font-medium text-text-muted hover:text-white transition-colors">
          Quick Start
        </a>
        <button id="search-btn" class="text-text-muted hover:text-white transition-colors" aria-label="Search (Ctrl+K)" onclick="window.__openSearch?.()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
        <a href="https://github.com/matt-cochran/tflo" target="_blank" rel="noopener" class="text-sm font-medium text-text-muted hover:text-white transition-colors">
          GitHub →
        </a>
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="sm:hidden text-text-muted hover:text-white transition-colors" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden sm:hidden flex-col gap-4 pb-4">
      <a href="/docs" class="text-sm font-medium text-text-muted hover:text-white transition-colors">Docs</a>
      <a href="/positioning" class="text-sm font-medium text-text-muted hover:text-white transition-colors">Positioning</a>
      <a href="/use-cases" class="text-sm font-medium text-text-muted hover:text-white transition-colors">Use Cases</a>
      <a href="/blog" class="text-sm font-medium text-text-muted hover:text-white transition-colors">Blog</a>
      <a href="/docs/quick-start" class="text-sm font-medium text-text-muted hover:text-white transition-colors">Quick Start</a>
      <a href="https://github.com/matt-cochran/tflo" target="_blank" rel="noopener" class="text-sm font-medium text-text-muted hover:text-white transition-colors">GitHub →</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
