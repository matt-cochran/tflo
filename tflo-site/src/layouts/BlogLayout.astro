---
import BaseLayout from './BaseLayout.astro';
import type { Props as BaseProps } from './BaseLayout.astro';

interface Props extends BaseProps {
  pubDate: Date;
  updatedDate?: Date;
  readingTime: number;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, readingTime, tags = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={pubDate.toISOString()} />
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    {tags.map(tag => <meta property="article:tag" content={tag} />)}
  </div>

  <article class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <!-- Header -->
    <header class="mb-10">
      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map(tag => (
            <span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
              {tag}
            </span>
          ))}
        </div>
      )}

      <h1 class="text-3xl sm:text-4xl font-extrabold text-white leading-tight">
        {title}
      </h1>

      {description && (
        <p class="mt-3 text-lg text-text-muted leading-relaxed">
          {description}
        </p>
      )}

      <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-text-muted">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <span class="hidden sm:inline">&middot;</span>
        <span>{readingTime} min read</span>
        {updatedDate && (
          <>
            <span class="hidden sm:inline">&middot;</span>
            <span>
              Updated{' '}
              <time datetime={updatedDate.toISOString()}>
                {updatedDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            </span>
          </>
        )}
      </div>
    </header>

    <!-- Content -->
    <div class="prose prose-invert prose-lg max-w-none
                prose-headings:text-white prose-headings:font-bold
                prose-a:text-primary hover:prose-a:text-primary-dark
                prose-code:text-accent prose-code:bg-bg-card prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
                prose-pre:bg-bg-card prose-pre:border prose-pre:border-border
                prose-strong:text-white
                prose-blockquote:border-primary prose-blockquote:text-text-muted
                prose-li:text-text-muted
                prose-hr:border-border">
      <slot />
    </div>
  </article>
</BaseLayout>
