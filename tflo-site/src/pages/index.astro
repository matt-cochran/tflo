            <td class="text-center p-4 text-emerald-400 font-bold">&#x2713;</td>
            <td class="text-center p-4">&#x2717;</td>
            <td class="text-center p-4">&#x2717;</td>
          </tr>
          <tr class="border-b border-border hover:bg-bg-card transition-colors">
            <td class="p-4">Checkpoint/restore</td>
            <td class="text-center p-4 text-emerald-400 font-bold">&#x2713;</td>
            <td class="text-center p-4">&#x2717;</td>
            <td class="text-center p-4">&#x2717;</td>
          </tr>
          <tr class="border-b border-border hover:bg-bg-card transition-colors">
            <td class="p-4">Lifecycle events (appeared / persisted / dropped out)</td>
            <td class="text-center p-4 text-emerald-400 font-bold">&#x2713;</td>
            <td class="text-center p-4">&#x2717;</td>
            <td class="text-center p-4">&#x2717;</td>
          </tr>
          <tr class="border-b border-border hover:bg-bg-card transition-colors">
            <td class="p-4">Iterator + Stream adapters</td>
            <td class="text-center p-4 text-emerald-400 font-bold">&#x2713;</td>
            <td class="text-center p-4">&#x2717;</td>
            <td class="text-center p-4">&#x2717;</td>
          </tr>
          <tr class="border-b border-border hover:bg-bg-card transition-colors">
            <td class="p-4">Async-native</td>
            <td class="text-center p-4 text-emerald-400 font-bold">&#x2713;</td>
            <td class="text-center p-4">&#x2717;</td>
            <td class="text-center p-4">&#x2717;</td>
          </tr>
