<span class="text-primary">|</span>       <span class="text-accent">|</span>  Cross <span class="text-accent">|</span> Hysteresis     <span class="text-accent">|</span>  Detectors     <span class="text-primary">|</span>
<span class="text-primary">|</span>       <span class="text-accent">|</span>  Glitch <span class="text-accent">|</span> Pulse <span class="text-accent">|</span> Runt  <span class="text-accent">|</span>                <span class="text-primary">|</span>
<span class="text-primary">|</span>       <span class="text-accent">|</span>  Window <span class="text-accent">|</span> Pulse-Width   <span class="text-accent">|</span>                <span class="text-primary">|</span>
<span class="text-primary">|</span>       <span class="text-accent">+-------------------------+</span>                <span class="text-primary">|</span>
<span class="text-primary">|</span>                                                  <span class="text-primary">|</span>
<span class="text-primary">|</span>  Lifecycle Events &lt;-- CompiledGraph &lt;-- Checkpoint<span class="text-primary">|</span>
<span class="text-primary">|</span>                                                  <span class="text-primary">|</span>
<span class="text-primary">+--------------------------------------------------+</span>
      </pre>
    </div>
  </section>

  <!-- Feature Matrix -->
