---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureCard from '../components/FeatureCard.astro';

const codeExample = `<span class="text-text-muted">use tflo_core::prelude::*;</span>

<span class="text-text-muted">// A noisy domain event — e.g. a sensor or detector reading</span>
<span class="text-text-muted">#[derive(Clone)]
struct Reading { ts: i64, level: f64 }</span>

<span class="text-text-muted">let readings = vec![
    Reading { ts: 1000, level: 100.0 },
    Reading { ts: 2000, level: 101.0 },
];</span>

<span class="text-text-muted">// Smooth the stream with a time-based moving average</span>
<span class="text-primary">let smoothed: Vec&lt;f64&gt;</span> = readings.into_iter()
    .<span class="text-accent">tflo</span>(|t| {
        t.timestamp(|x| x.ts);
        <span class="text-accent">let level = t.prop(|x| x.level);</span>
        level.sma(2_u64.secs())
    })
    .collect();`;
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-linear-to-br from-primary/10 via-transparent to-accent/10" />
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-24 sm:py-36">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 rounded-full border border-border bg-bg-card px-4 py-1.5 text-sm text-text-muted mb-8">
          <span class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span>
          Experimental &middot; pre-1.0
        </div>
        <h1 class="text-4xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-white leading-tight">
          A
          <span class="gradient-text">Temporal Event Processing</span>
          Engine
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-text-muted max-w-2xl mx-auto leading-relaxed">
          tflo &mdash; short for &ldquo;temporal flow&rdquo; &mdash; turns noisy domain events into clean
          lifecycle events: <em>appeared</em>, <em>persisted</em>, <em>changed</em>,
          <em>dropped out</em>, <em>crossed a threshold</em>. Composable computation graphs over
          iterators and streams, with first-class keyed execution, checkpoint/restore, and observability.
        </p>
        <p class="mt-3 text-md text-primary/80 max-w-2xl mx-auto leading-relaxed font-medium">
          Model your domain events; layer streaming temporal analysis on top.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/docs/quick-start" class="btn-primary text-base px-8 py-3.5">
            Get Started
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4l4 4-4 4"/></svg>
          </a>
          <a href="#features" class="btn-secondary text-base px-8 py-3.5">
            Features
          </a>
          <a href="/use-cases" class="btn-secondary text-base px-8 py-3.5">
            Use Cases
          </a>
          <a href="https://github.com/matt-cochran/tflo" target="_blank" rel="noopener" class="btn-secondary text-base px-8 py-3.5">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
        </div>
      </div>
    </div>
  </section>

