<span class="text-primary">+--------------------------------------------------+</span>
<span class="text-primary">|</span>                                                  <span class="text-primary">|</span>
<span class="text-primary">|</span>   Noisy Events --&gt; tflo() --&gt; Keyed Execution    <span class="text-primary">|</span>
<span class="text-primary">|</span>                                                  <span class="text-primary">|</span>
<span class="text-primary">|</span>       <span class="text-accent">+-------------------------+</span>                <span class="text-primary">|</span>
<span class="text-primary">|</span>       <span class="text-accent">|</span>  sma <span class="text-accent">|</span> ema <span class="text-accent">|</span> std <span class="text-accent">|</span> rate <span class="text-accent">|</span>  Streaming     <span class="text-primary">|</span>
<span class="text-primary">|</span>       <span class="text-accent">|</span>  deviation_band   <span class="text-accent">|</span> ..   <span class="text-accent">|</span>  Analysis      <span class="text-primary">|</span>
<span class="text-primary">|</span>       <span class="text-accent">|</span>  peak_decline <span class="text-accent">|</span> momentum <span class="text-accent">|</span>                <span class="text-primary">|</span>
<span class="text-primary">|</span>       <span class="text-accent">+-------------------------+</span>                <span class="text-primary">|</span>
