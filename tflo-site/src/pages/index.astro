    <div class="text-center mt-8">
      <a href="/docs/quick-start" class="btn-primary">
        Full Quick Start Guide
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4l4 4-4 4"/></svg>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-20 border-t border-border">
    <div class="card text-center py-16 relative overflow-hidden">
      <div class="absolute inset-0 bg-linear-to-br from-primary/5 to-accent/5" />
      <div class="relative">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white">Ready to model your events?</h2>
        <p class="mt-4 text-lg text-text-muted max-w-lg mx-auto">
          Add <code>tflo-core</code> to your <code>Cargo.toml</code> and start building
          real-time event-processing pipelines today.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/docs/quick-start" class="btn-primary text-lg px-10 py-4">Get Started</a>
          <a href="/playground" class="btn-accent text-lg px-10 py-4">Try the Playground</a>
          <a href="/docs" class="btn-secondary text-lg px-10 py-4">Browse Docs</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
