    <div class="text-center mb-14">
      <h2 class="section-title">Why tflo?</h2>
      <p class="section-subtitle">Built from the ground up for real-time streaming workloads.</p>
    </div>

    <div class="overflow-x-auto rounded-xl border border-border">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border bg-bg-card">
            <th class="text-left p-4 font-semibold text-white">Capability</th>
            <th class="text-center p-4 font-semibold"><span class="gradient-text">tflo</span></th>
            <th class="text-center p-4 font-semibold text-text-muted">Hand-rolled state</th>
            <th class="text-center p-4 font-semibold text-text-muted">Batch jobs / SQL</th>
          </tr>
        </thead>
        <tbody class="text-text-muted">
          <tr class="border-b border-border hover:bg-bg-card transition-colors">
            <td class="p-4">Streaming-first &mdash; no full history in memory</td>
            <td class="text-center p-4 text-emerald-400 font-bold">&#x2713;</td>
            <td class="text-center p-4">&#x2717;</td>
            <td class="text-center p-4">&#x2717; (batch)</td>
          </tr>
          <tr class="border-b border-border hover:bg-bg-card transition-colors">
