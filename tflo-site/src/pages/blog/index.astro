---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="Deep dives on streaming technical analysis, computation graphs, and Rust.">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="mb-12">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white">Blog</h1>
      <p class="mt-4 text-lg sm:text-xl text-text-muted max-w-2xl">
        Evergreen posts about tflo — architecture deep dives, indicator implementations,
        performance notes, and real-world usage patterns.
      </p>
    </div>

    {
      allPosts.length > 0 ? (
        <div class="space-y-8">
          {
            allPosts.map((post) => (
              <article class="card transition-colors hover:bg-bg-card-hover">
                <a href={`/blog/${post.slug}`} class="block no-underline">
                  {post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-3">
                      {post.data.tags.map(tag => (
                        <span class="inline-block rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-semibold text-primary">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}

                  <h2 class="text-xl sm:text-2xl font-bold text-white group-hover:text-primary transition-colors">
                    {post.data.title}
                  </h2>

                  {post.data.description && (
                    <p class="mt-2 text-text-muted line-clamp-2">
                      {post.data.description}
                    </p>
                  )}

                  <div class="mt-4 flex items-center gap-3 text-sm text-text-muted">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                      })}
                    </time>
                    <span>&middot;</span>
                    <span>{post.data.tags.length > 0 ? post.data.tags.join(', ') : 'post'}</span>
                  </div>
                </a>
              </article>
            ))
          }
        </div>
      ) : (
        <div class="text-center py-20">
          <p class="text-text-muted text-lg">No posts yet. Check back soon!</p>
        </div>
      )
    }
  </div>
</BaseLayout>
