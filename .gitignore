.vscode/
*.swp
*.swo
*~

# ── OS ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.Zone.Identifier

# ── Python (fixture generators in tflo-fintech/tests/golden/scripts/) ─
__pycache__/
*.pyc

